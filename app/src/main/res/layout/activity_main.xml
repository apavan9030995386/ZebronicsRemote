<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ZEBRONICS PIXAPLAY"
            android:textColor="#00D4FF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginTop="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PROJECTOR REMOTE"
            android:textColor="#6B6B9A"
            android:textSize="11sp"
            android:letterSpacing="0.2"
            android:layout_marginBottom="8dp"/>

        <!-- Status -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Checking IR blaster..."
            android:textColor="#6B6B9A"
            android:textSize="12sp"
            android:layout_marginBottom="20dp"/>

        <!-- Remote Card -->
        <LinearLayout
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/remote_bg"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <!-- Power Button -->
            <Button
                android:id="@+id/btnPower"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="⏻"
                android:textSize="22sp"
                android:textColor="#FF3A5C"
                android:background="@drawable/btn_power"
                android:layout_marginBottom="16dp"/>

            <!-- Top Row: Mute, Source, Aspect -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:id="@+id/btnMute"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_normal"
                    android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔇" android:textSize="16sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MUTE" android:textColor="#6B6B9A" android:textSize="8sp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnSource"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_normal"
                    android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⬛" android:textSize="16sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SOURCE" android:textColor="#6B6B9A" android:textSize="8sp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnAspect"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_normal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⛶" android:textSize="16sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RATIO" android:textColor="#6B6B9A" android:textSize="8sp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- D-Pad -->
            <RelativeLayout
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_marginBottom="14dp">

                <Button
                    android:id="@+id/btnUp"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text="▲"
                    android:textColor="#E8E8FF"
                    android:background="@drawable/btn_normal"
                    android:layout_centerHorizontal="true"
                    android:layout_alignParentTop="true"/>

                <Button
                    android:id="@+id/btnLeft"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text="◀"
                    android:textColor="#E8E8FF"
                    android:background="@drawable/btn_normal"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"/>

                <Button
                    android:id="@+id/btnOK"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:text="OK"
                    android:textColor="#00D4FF"
                    android:textStyle="bold"
                    android:background="@drawable/btn_ok"
                    android:layout_centerInParent="true"/>

                <Button
                    android:id="@+id/btnRight"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text="▶"
                    android:textColor="#E8E8FF"
                    android:background="@drawable/btn_normal"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"/>

                <Button
                    android:id="@+id/btnDown"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text="▼"
                    android:textColor="#E8E8FF"
                    android:background="@drawable/btn_normal"
                    android:layout_centerHorizontal="true"
                    android:layout_alignParentBottom="true"/>

            </RelativeLayout>

            <!-- Action Row: Back, Home, Menu -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:id="@+id/btnBack"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_normal"
                    android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="↩" android:textColor="#E8E8FF" android:textSize="18sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BACK" android:textColor="#6B6B9A" android:textSize="8sp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnHome"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_normal"
                    android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⌂" android:textColor="#E8E8FF" android:textSize="18sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HOME" android:textColor="#6B6B9A" android:textSize="8sp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnMenu"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_normal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="☰" android:textColor="#E8E8FF" android:textSize="18sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MENU" android:textColor="#6B6B9A" android:textSize="8sp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Volume Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:background="@drawable/btn_normal"
                android:layout_marginBottom="14dp">

                <Button
                    android:id="@+id/btnVolDown"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="−"
                    android:textSize="22sp"
                    android:textColor="#E8E8FF"
                    android:background="?attr/selectableItemBackground"/>

                <TextView
                    android:layout_width="60dp"
                    android:layout_height="match_parent"
                    android:text="VOL"
                    android:textColor="#6B6B9A"
                    android:textSize="9sp"
                    android:gravity="center"
                    android:letterSpacing="0.15"/>

                <Button
                    android:id="@+id/btnVolUp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="+"
                    android:textSize="22sp"
                    android:textColor="#E8E8FF"
                    android:background="?attr/selectableItemBackground"/>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1A00D4FF"
                android:layout_marginBottom="14dp"/>

            <!-- Streaming Buttons -->
            <Button
                android:id="@+id/btnNetflix"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="NETFLIX"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:background="@drawable/btn_netflix"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnYoutube"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="▶  YouTube"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/btn_youtube"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnPrime"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="prime video"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_prime"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Point top of phone at projector IR receiver"
            android:textColor="#6B6B9A"
            android:textSize="11sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp"/>

    </LinearLayout>
</ScrollView>
